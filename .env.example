# COOKIE AI Video Production Framework
# Copy to ~/.claude/.env and fill in your API keys

# Google API Key (required for VEO video + Gemini image generation)
# Get yours at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# ElevenLabs API Key (required for narration)
# Get yours at: https://elevenlabs.io (Settings > API Keys)
ELEVENLABS_API_KEY=
